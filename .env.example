# Core — copy to .env before docker compose up or local Gradle run
# All variables below are required unless noted.

POSTGRES_USER=babaai
POSTGRES_PASSWORD=babaai_secret
POSTGRES_DB=babaai
POSTGRES_PORT=5432
DATABASE_URL=jdbc:postgresql://postgres:5432/babaai

CORE_PORT=8081
# Short-lived access token; renewed via the refresh-token cookie.
JWT_EXPIRE_MINUTES=15
# Docker: /app/keys  |  Local Gradle: ./keys
JWT_KEY_PATH=/app/keys

# Refresh token (optional — sensible defaults shown).
REFRESH_EXPIRE_DAYS=30
# Set false for local dev over http (a Secure cookie is not sent over http).
REFRESH_COOKIE_SECURE=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Must match babaai-ai/.env AI_SERVICE_TOKEN
AI_SERVICE_TOKEN=babaai-ai-service-token
AI_SERVICE_URL=http://host.docker.internal:8082

# Gateway internal URL for pushing token-revocation events. Auth is a short-lived RS256 service
# token signed by core and verified via core's JWKS — no shared secret to configure. See 869dqmbfp.
GATEWAY_INTERNAL_URL=http://host.docker.internal:8000

DEFAULT_MIN_MATCH_PERCENT=50
DEFAULT_SUGGESTION_LIMIT=20
DEFAULT_PAGE_SIZE=20
DEFAULT_INGREDIENT_CATEGORY=Other

# Daily personalized suggestions (869dr0a4d) — optional, sensible defaults shown.
# SUGGESTIONS_SCHEDULER_ENABLED=true
# Spring cron (sec min hour dom mon dow): generate each user's "Today for you" set every morning.
# SUGGESTIONS_CRON=0 0 6 * * *
# SUGGESTIONS_DAILY_LIMIT=6
# Pantry items expiring within this many days get the waste-reduction boost.
# SUGGESTIONS_EXPIRY_SOON_DAYS=3
# Don't re-suggest recipes seen in the last N days.
# SUGGESTIONS_RECENCY_DAYS=3

# User recipe-import uploads (869dtx7tj) — optional, sensible defaults shown.
# Framework multipart caps (Spring parses sizes like 10MB / 1024KB).
# IMPORT_MAX_FILE_SIZE=10MB
# IMPORT_MAX_REQUEST_SIZE=12MB
# Friendlier per-file limit enforced in the service (bytes). 5 MB default.
# IMPORT_MAX_FILE_SIZE_BYTES=5242880

# Optional — override bundled JSON config paths (defaults use classpath:config/*.json)
# INGREDIENT_CATEGORY_CONFIG_PATH=classpath:config/ingredient_categories.json
# UNIT_CONVERSION_CONFIG_PATH=classpath:config/unit_conversion.json
# SEED_RECIPES_CONFIG_PATH=classpath:config/sample_recipes.json
# APP_DEFAULTS_CONFIG_PATH=classpath:config/app_defaults.json
# RECIPE_CATEGORIES_CONFIG_PATH=classpath:config/recipe_categories.json
# INGREDIENT_NUTRITION_CONFIG_PATH=classpath:config/ingredient_nutrition.json
# DIETARY_RULES_CONFIG_PATH=classpath:config/dietary_rules.json
