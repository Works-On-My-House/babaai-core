# Core — copy to .env before docker compose up or local Gradle run
# All variables below are required unless noted.

POSTGRES_USER=babaai
POSTGRES_PASSWORD=babaai_secret
POSTGRES_DB=babaai
POSTGRES_PORT=5432
DATABASE_URL=jdbc:postgresql://postgres:5432/babaai

CORE_PORT=8081
JWT_EXPIRE_MINUTES=60
# Docker: /app/keys  |  Local Gradle: ./keys
JWT_KEY_PATH=/app/keys

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Must match babaai-ai/.env AI_SERVICE_TOKEN
AI_SERVICE_TOKEN=babaai-ai-service-token
AI_SERVICE_URL=http://host.docker.internal:8082

DEFAULT_MIN_MATCH_PERCENT=50
DEFAULT_SUGGESTION_LIMIT=20
DEFAULT_PAGE_SIZE=20
DEFAULT_INGREDIENT_CATEGORY=Other

# Optional — override bundled JSON config paths (defaults use classpath:config/*.json)
# INGREDIENT_CATEGORY_CONFIG_PATH=classpath:config/ingredient_categories.json
# UNIT_CONVERSION_CONFIG_PATH=classpath:config/unit_conversion.json
# SEED_RECIPES_CONFIG_PATH=classpath:config/sample_recipes.json
# APP_DEFAULTS_CONFIG_PATH=classpath:config/app_defaults.json
# RECIPE_CATEGORIES_CONFIG_PATH=classpath:config/recipe_categories.json
